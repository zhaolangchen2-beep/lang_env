# Spark Cluster Environment Variables

# 宿主机IP地址（用于外部访问）
# 如果不设置，默认为localhost
HOST_IP=141.61.61.143

# Spark资源配置
SPARK_WORKER_CORES=4
SPARK_WORKER_MEMORY=16g
SPARK_DRIVER_MEMORY=16g
SPARK_EXECUTOR_MEMORY=16g

# 网络配置
SPARK_NETWORK_SUBNET=172.30.0.0/16
SPARK_NETWORK_GATEWAY=172.30.0.1

# 日志级别
SPARK_LOG_LEVEL=INFO
